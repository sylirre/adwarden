    <string name="settings_install_ca_sub">Trust the root certificate so decryption can work.</string>
    <string name="settings_nonroot_limits">Non-root limits</string>
    <string name="settings_nonroot_limits_body">Without root, Android only lets us decrypt apps that trust user certificates (e.g. Chrome). Blocking, logging and PCAP still work for every app.</string>
    <string name="settings_system_integration">System integration</string>
    <string name="settings_always_on">Always-on VPN</string>
    <string name="settings_always_on_sub">Open Android\'s VPN settings to keep Adwarden always connected, and optionally block traffic while it\'s off (lockdown).</string>
    <string name="settings_qs_tile">Quick Settings tile</string>
    <string name="settings_qs_tile_sub">Add the Adwarden tile from the Quick Settings edit panel to toggle protection without opening the app.</string>
    <string name="settings_about">About</string>
