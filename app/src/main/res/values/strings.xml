    <string name="settings_core_title">On-device core</string>
    <string name="settings_core_body">Filtering, the per-app firewall and HTTPS inspection all run in a native core on your phone — no traffic is sent to any server.</string>

    <!-- CA install wizard -->
    <string name="ca_what_decrypts">What this can decrypt</string>
    <string name="ca_what_decrypts_body">Since Android 7, apps only trust user-installed CAs if they opt in. Browsers like Chrome and Firefox do; many apps pin their certificates and stay opaque. Blocking, logging and PCAP keep working for every app — only full HTTPS decode is limited to the cooperating subset.</string>
    <string name="ca_preparing">Preparing certificate…</string>
    <string name="ca_install_cert">Install certificate</string>
    <string name="ca_export_pem">Export .pem</string>
    <string name="ca_steps_34">1. Tap Install certificate below.\n2. The system will ask what to install — choose \"CA certificate\".\n3. Confirm the security warning to trust the Adwarden CA.\nIf the picker doesn\'t appear, use Export .pem, then Settings ▸ Security &amp; privacy ▸ More security ▸ Encryption &amp; credentials ▸ Install a certificate ▸ CA certificate, and pick the exported file.</string>
    <string name="ca_steps_30">1. Tap Install certificate below and choose \"CA certificate\".\n2. Confirm the security warning.\nOtherwise Export .pem and install it via Settings ▸ Security ▸ Encryption &amp; credentials ▸ Install a certificate ▸ CA certificate.</string>
    <string name="ca_steps_legacy">Tap Install certificate and choose \"CA certificate\", or Export .pem and install it from Settings ▸ Security ▸ Install from storage.</string>

    <!-- Onboarding -->
    <string name="onb_tagline">Block ads and trackers, run a per-app firewall, and inspect every connection — no root required.</string>
    <string name="onb_feat_filter_title">Rule-based filtering</string>
    <string name="onb_feat_filter_sub">Subscribe to AdGuard and EasyList rule sets, or write your own.</string>
    <string name="onb_feat_firewall_title">Per-app firewall</string>
    <string name="onb_feat_firewall_sub">Cut off any app on Wi-Fi or mobile data independently.</string>
    <string name="onb_feat_traffic_title">Live traffic &amp; capture</string>
    <string name="onb_feat_traffic_sub">Watch connections in real time and export PCAP for analysis.</string>
    <string name="onb_continue">Continue</string>
    <string name="onb_vpn_title">Allow the private VPN</string>
    <string name="onb_vpn_body">Adwarden filters and inspects traffic through a local, on-device VPN. There is no remote server — the tunnel never leaves your phone. Android shows a one-time consent prompt for this.</string>
    <string name="onb_vpn_cta">Grant VPN access</string>
    <string name="onb_notif_title">Show a status notification</string>
    <string name="onb_notif_body">While protection runs, Android keeps a permanent notification so you always know Adwarden is active. Allow it to keep that indicator visible.</string>
    <string name="onb_notif_cta">Allow notifications</string>
    <string name="onb_done_title">You\'re all set</string>
    <string name="onb_done_body">Turn on protection from the dashboard whenever you\'re ready. To decrypt HTTPS for inspection later, install the Adwarden CA — it\'s optional and off by default.</string>
    <string name="onb_install_ca">Install Adwarden CA</string>
    <string name="onb_start">Start using Adwarden</string>
    <string name="onb_skip">Skip for now</string>
