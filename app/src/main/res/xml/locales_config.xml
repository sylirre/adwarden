<?xml version="1.0" encoding="utf-8"?>
<!-- Per-app languages for the Android 13+ system language picker (P3-7). English
     is the default (res/values); Russian is the seeded translation. -->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="ru" />
</locale-config>
